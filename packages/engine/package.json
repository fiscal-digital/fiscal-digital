{
  "name": "@fiscal-digital/engine",
  "version": "0.1.1",
  "description": "Fiscais, Skills e contratos TypeScript do Fiscal Digital",
  "license": "MIT",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "files": [
    "dist/**/*.js",
    "dist/**/*.d.ts",
    "dist/**/*.d.ts.map",
    "dist/**/*.json",
    "dist/**/*.md",
    "!dist/**/__tests__/**",
    "!dist/**/*.test.*"
  ],
  "repository": {
    "type": "git",
    "url": "https://github.com/fiscal-digital/fiscal-digital.git",
    "directory": "packages/engine"
  },
  "publishConfig": {
    "registry": "https://npm.pkg.github.com",
    "access": "public"
  },
  "engines": {
    "node": ">=24"
  },
  "scripts": {
    "sync": "node scripts/sync-brand.mjs",
    "prebuild": "node scripts/sync-brand.mjs",
    "build": "tsc",
    "postbuild": "node scripts/copy-assets.mjs",
    "prepack": "npm run build",
    "pretest": "node scripts/sync-brand.mjs",
    "test": "jest --passWithNoTests",
    "lint": "eslint src --ext .ts"
  },
  "dependencies": {
    "@anthropic-ai/sdk": "^0.91.0",
    "@aws-lambda-powertools/logger": "^2.33.0",
    "@aws-sdk/client-bedrock-runtime": "^3.1041.0",
    "@aws-sdk/client-dynamodb": "^3.0.0",
    "@aws-sdk/client-secrets-manager": "^3.0.0",
    "@aws-sdk/client-ssm": "^3.1041.0",
    "@aws-sdk/lib-dynamodb": "^3.0.0"
  },
  "devDependencies": {
    "@types/jest": "^30.0.0",
    "@types/node": "^26.1.1",
    "jest": "^30.0.0",
    "ts-jest": "^29.4.0",
    "typescript": "^7.0.2"
  }
}
